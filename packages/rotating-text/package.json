{
  "name": "@bimaputrasena/rotating-text",
  "version": "0.1.0",
  "description": "Lightweight, accessible animated rotating word component for React 18+. Zero dependencies, respects prefers-reduced-motion, CLS-safe.",
  "keywords": [
    "react",
    "rotating-text",
    "animated-text",
    "typing-effect",
    "accessibility",
    "tailwind",
    "headline"
  ],
  "author": "Bima Putra Sena <bima@appvibe.web.id>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bimaputrasena/rotating-text.git"
  },
  "homepage": "https://github.com/bimaputrasena/rotating-text#readme",
  "bugs": {
    "url": "https://github.com/bimaputrasena/rotating-text/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
